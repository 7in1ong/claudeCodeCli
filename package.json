{
  "name": "claude-code-cli",
  "version": "0.1.0",
  "description": "A CLI tool for interacting with Claude AI",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "claude-code": "dist/cli/index.js",
    "claude-code-cli": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "ink": "^5.2.1",
    "marked": "^15.0.12",
    "ora": "^8.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
